aws_region           = "us-east-1"
environment          = "dev"
project_name         = "teams-rag-chatbot"
generation_model_id  = "anthropic.claude-3-haiku-20240307-v1:0"
embedding_model_id   = "amazon.titan-embed-text-v2:0"
db_name              = "ragdb"

# Networking
vpc_id             = "vpc-xxxxxxxxx"
vpc_cidr           = "10.0.0.0/16"
private_subnet_ids = ["subnet-xxx", "subnet-yyy"]

# SharePoint configuration
# sharepoint_tenant_id     = "your-tenant-id"
# sharepoint_client_id     = "your-client-id"
# sharepoint_client_secret = "your-client-secret"
sharepoint_site_url        = "https://yourtenant.sharepoint.com/sites/your-site"

# Aurora PostgreSQL
# db_master_password = "your-secure-password"

# Bot configuration
# (Azure Bot registration handled separately)
